{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": "."
  },
  "include": [
    "agents/**/*.ts",
    "scripts/**/*.ts",
    "spectator/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
