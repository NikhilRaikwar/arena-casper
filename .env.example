# -- Casper Testnet -------------------------------------------------
ARENA_MODE=mock
ARENA_NETWORK=testnet
ARENA_CHAIN_NAME=casper-test
ARENA_CONTRACT_HASH=
ARENA_PACKAGE_HASH=
CSPR_CLOUD_API_KEY=
CSPR_CLOUD_EVENTS_URL=
TESTNET_RPC=https://node.testnet.casper.network/rpc
ARENA_RPC_URL=https://node.testnet.casper.network/rpc
CSPR_LIVE_BASE_URL=https://testnet.cspr.live/deploy

# -- Agent and verifier keys --------------------------------------
AGENT_ALPHA_KEY_PATH=./keys/agent-alpha.pem
AGENT_BETA_KEY_PATH=./keys/agent-beta.pem
VERIFIER_KEY_PATH=./keys/verifier.pem
ARENA_CREATOR_SECRET_KEY=./keys/verifier.pem
ARENA_ALPHA_SECRET_KEY=./keys/agent-alpha.pem
ARENA_BETA_SECRET_KEY=./keys/agent-beta.pem
ARENA_VERIFIER_SECRET_KEY=./keys/verifier.pem
ARENA_KEY_ALGORITHM=ed25519

# -- Public accounts ----------------------------------------------
ARENA_CREATOR_ACCOUNT=
ARENA_ALPHA_ACCOUNT=
ARENA_BETA_ACCOUNT=
ARENA_VERIFIER_ACCOUNT=

# -- AI via OpenRouter --------------------------------------------
OPENROUTER_API_KEY=sk-or-v1-
AI_MODEL=meta-llama/llama-3.1-8b-instruct:free
# AI_MODEL=anthropic/claude-sonnet-4-5

# -- Match settings -----------------------------------------------
MATCH_ID=1
MATCH_DURATION_BLOCKS=20
MATCH_START_BUDGET=1000000000000
MATCH_POLL_MS=5000
TICK_MS=120000
DEPLOY_TIMEOUT_MS=90000
PAYMENT_MOTES=3000000000
SPECTATOR_PORT=3001
AGENT_ITERATIONS=1
