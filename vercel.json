{
  "version": 2,
  "cleanUrls": true,
  "builds": [
    {
      "src": "spectator/server.ts",
      "use": "@vercel/node"
    },
    {
      "src": "spectator/public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "spectator/server.ts"
    },
    {
      "src": "/events",
      "dest": "spectator/server.ts"
    },
    {
      "src": "/dashboard",
      "dest": "/dashboard.html"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
