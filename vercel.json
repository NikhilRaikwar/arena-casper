{
  "version": 2,
  "builds": [
    {
      "src": "spectator/server.ts",
      "use": "@vercel/node"
    },
    {
      "src": "spectator/public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "spectator/server.ts"
    },
    {
      "src": "/events",
      "dest": "spectator/server.ts"
    },
    {
      "src": "/(.*)",
      "dest": "spectator/public/$1"
    }
  ]
}
